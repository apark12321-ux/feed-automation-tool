# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Personal automation limits
POSTS_PER_DAY=3
RUN_TIMEZONE=Asia/Seoul
COLLECT_CRON=0 7 * * *
GENERATE_CRON=30 7 * * *
PUBLISH_CRON=*/15 * * * *

# RSS feeds, comma separated
RSS_FEEDS=https://news.google.com/rss/search?q=AI+%EC%8B%9C%EB%8B%88%EC%96%B4&hl=ko&gl=KR&ceid=KR:ko

# Brand defaults
BRAND_NAME=FeedFlow Auto
BRAND_TONE=명확하고 신뢰감 있는 전문가 톤
BRAND_COLOR_A=#18d5ff
BRAND_COLOR_B=#8b5cf6

# Meta Instagram Graph API
META_ACCESS_TOKEN=
META_IG_USER_ID=
PUBLIC_BASE_URL=

# Local server
PORT=8787
